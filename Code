#define BLYNK_TEMPLATE_ID "TMPL3I7f5KQA3"
#define BLYNK_TEMPLATE_NAME "MOTION BASED HOME AUTOMATION"
#define BLYNK_AUTH_TOKEN "Ww8n6HounNiNMtV5hj3AaYgb1BDa8yvk"
#define BLYNK_PRINT Serial

#include <Wire.h>
#include <BH1750.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME280.h>
#include <WiFi.h>
#include <WiFiClient.h>
#include <BlynkSimpleEsp32.h>

#define Mode 12
#define Security 0
#define PIR_PIN 2
#define LED_PIN 4
#define MOTION_DELAY 3000
#define BH1750_ADDRESS 0x23

const int relayPin = 13;
int flag = 0; // Correctly declaring flag as an int

BH1750 lightMeter;
Adafruit_BME280 bme;
 

char WIFI_SSID[] = "Galaxy 5G4460";
char WIFI_PASS[] = "";

void setup() {
  Serial.begin(115200);
  Serial.println("beginning setup");
  lightMeter.begin(BH1750::CONTINUOUS_HIGH_RES_MODE);
  pinMode(PIR_PIN, INPUT);
  pinMode(LED_PIN, OUTPUT);
  pinMode(relayPin, OUTPUT);
  Blynk.begin(BLYNK_AUTH_TOKEN, WIFI_SSID, WIFI_PASS);

   

  if (!bme.begin(0x76)) {
    Serial.println("Could not find a valid BME280 sensor, check wiring!");
    while (1);
  }
if (!lightMeter.begin()) {
    Serial.println(F("BH1750 sensor not found"));
    while (1);
  }
  else{ Serial.println(F("BH1750 found"));}

}

void loop() {
  Blynk.run();
  if (digitalRead(Mode) == LOW) {
    if(digitalRead(Security)==LOW)
      {
    if (digitalRead(PIR_PIN) == HIGH) {     
      while (digitalRead(PIR_PIN) == HIGH) {
        float lightIntensity = lightMeter.readLightLevel();
        float temperature = bme.readTemperature();
        float humidity = bme.readHumidity();
        Serial.print(" | Motion Detected: ");
        Serial.println(PIR_PIN);
        Serial.print("Light Intensity: ");
        Serial.println(lightIntensity);
        Serial.print("Temperature: ");
        Serial.print(temperature);
        Serial.println(" °C");
        Serial.print("Humidity: ");
        Serial.print(humidity);
        Serial.println(" %");

        Blynk.virtualWrite(V5, temperature);
        Blynk.virtualWrite(V6, humidity);
        Blynk.virtualWrite(V0, lightIntensity);

        if (flag == 0) {
          if (lightIntensity <= 20) {
            flag = 1; // Setting the flag correctly
            digitalWrite(LED_PIN, HIGH);
            Serial.println("Switching LED ON");
            Blynk.virtualWrite(V4, HIGH);
          } else {
            digitalWrite(LED_PIN, LOW);
            Serial.println("Enough light");
            Blynk.virtualWrite(V4, LOW);
          }
        }

        if (temperature > 20) {
          digitalWrite(relayPin, LOW);
          Serial.println("Fan ON");
          Blynk.virtualWrite(V3, HIGH);
        } else {
          digitalWrite(relayPin, HIGH);
          Serial.println("Fan OFF");
          Blynk.virtualWrite(V3, LOW);
        }
        delay(500);
      }
      Serial.println("Motion has stopped");
    } else {
      int i = 0;
      while (digitalRead(PIR_PIN) == LOW && i < 5) {
        delay(1000);
        Serial.println(i);
        i++;
      }
      if (i == 5 && digitalRead(PIR_PIN) == LOW) {
        Serial.println("NO Motion detected!");
        Serial.println("Turning LED OFF");
        digitalWrite(LED_PIN, LOW);
        flag = 0; // Resetting the flag correctly
        digitalWrite(relayPin, HIGH);
        Blynk.virtualWrite(V3, LOW);
        Blynk.virtualWrite(V4, LOW);
      }
    }
  }
  else
  {
    if(digitalRead(PIR_PIN)==HIGH)
    {
      Serial.println("Theft Alert");
      flag = 0;
      digitalWrite(LED_PIN, LOW);
      digitalWrite(relayPin, HIGH);
      Blynk.logEvent("security_","SECURITY ALERT !!!!!");
      delay(1000);
    }
  }
}
}
